{
  "name": "@revivifai/eslint-config",
  "version": "0.1.3",
  "description": "RevivifAI's ESLint configuration for TypeScript projects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "typescript",
    "prettier",
    "revivifai"
  ],
  "author": "RevivifAI",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RevivifAI/eslint-config-revivifai.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@seahax/eslint-plugin-wrap": "^0.6.11",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-yml": "^1.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "eslint": "^10.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  }
}
